DATABASE_URL=postgresql+asyncpg://[db_user]:[db_password]@localhost:5432/mgp_db
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
FRONTEND_URL=http://localhost:5173

# SMTP — leave SMTP_HOST empty to log emails to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mygreenplanner.com
SMTP_TLS=true

# Sysadmin bootstrap account
SYSADMIN_EMAIL=sysadmin@mgp.local
SYSADMIN_PASSWORD=change-me-strong-password
SYSADMIN_NAME=System Administrator

# Monday.com integration — leave MONDAY_API_TOKEN empty to disable.
# Each generated proposal creates a new item on MONDAY_BOARD_ID under
# MONDAY_GROUP_ID and posts an update on that item with the PDF + xlsx
# files attached (no dedicated file column needed on the board).
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_GROUP_ID=
