POSTGRES_PASSWORD=changeme
SECRET_KEY=changeme-use-a-long-random-string
FRONTEND_URL=https://your-domain.com

# SMTP — leave SMTP_HOST empty to log emails to console (dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@mygreenplanner.com
SMTP_TLS=true

# Sysadmin bootstrap account
SYSADMIN_EMAIL=sysadmin@mgp.local
SYSADMIN_PASSWORD=change-me-strong-password
SYSADMIN_NAME=System Administrator

# Monday.com integration — leave MONDAY_API_TOKEN empty to disable.
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
MONDAY_GROUP_ID=
# "Get Quotation" target — empty falls back to MONDAY_BOARD_ID / MONDAY_GROUP_ID.
MONDAY_QUOTATION_BOARD_ID=
MONDAY_QUOTATION_GROUP_ID=
